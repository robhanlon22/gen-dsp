{
  "name": "ring_mod",
  "inputs": [
    {"id": "in1"}
  ],
  "outputs": [
    {"id": "out1", "source": "output"}
  ],
  "params": [
    {"name": "freq", "min": 20.0, "max": 2000.0, "default": 200.0},
    {"name": "mix", "min": 0.0, "max": 1.0, "default": 0.5}
  ],
  "nodes": [
    {"id": "carrier", "op": "sinosc", "freq": "freq"},
    {"id": "ring", "op": "mul", "a": "in1", "b": "carrier"},
    {"id": "inv_mix", "op": "sub", "a": 1.0, "b": "mix"},
    {"id": "dry", "op": "mul", "a": "in1", "b": "inv_mix"},
    {"id": "wet", "op": "mul", "a": "ring", "b": "mix"},
    {"id": "output", "op": "add", "a": "dry", "b": "wet"}
  ]
}
