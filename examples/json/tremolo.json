{
  "name": "tremolo",
  "inputs": [
    {"id": "in1"}
  ],
  "outputs": [
    {"id": "out1", "source": "output"}
  ],
  "params": [
    {"name": "rate", "min": 0.5, "max": 20.0, "default": 5.0},
    {"name": "depth", "min": 0.0, "max": 1.0, "default": 0.5}
  ],
  "nodes": [
    {"id": "lfo", "op": "sinosc", "freq": "rate"},
    {"id": "lfo_uni", "op": "mul", "a": "lfo", "b": 0.5},
    {"id": "lfo_offset", "op": "add", "a": "lfo_uni", "b": 0.5},
    {"id": "mod_depth", "op": "mul", "a": "lfo_offset", "b": "depth"},
    {"id": "base", "op": "sub", "a": 1.0, "b": "depth"},
    {"id": "gain", "op": "add", "a": "base", "b": "mod_depth"},
    {"id": "output", "op": "mul", "a": "in1", "b": "gain"}
  ]
}
