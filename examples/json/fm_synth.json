{
  "name": "fm_synth",
  "inputs": [],
  "outputs": [
    {"id": "out1", "source": "output"}
  ],
  "params": [
    {"name": "gate", "min": 0.0, "max": 1.0, "default": 0.0},
    {"name": "freq", "min": 20.0, "max": 2000.0, "default": 440.0},
    {"name": "mod_ratio", "min": 0.5, "max": 8.0, "default": 2.0},
    {"name": "mod_index", "min": 0.0, "max": 10.0, "default": 3.0},
    {"name": "amp", "min": 0.0, "max": 1.0, "default": 0.3}
  ],
  "nodes": [
    {"id": "sine_tbl", "op": "buffer", "size": 512, "fill": "sine"},

    {"id": "mod_freq", "op": "mul", "a": "freq", "b": "mod_ratio"},
    {"id": "mod_phasor", "op": "phasor", "freq": "mod_freq"},
    {"id": "mod_osc", "op": "cycle", "buffer": "sine_tbl", "phase": "mod_phasor"},

    {"id": "dev_scale", "op": "mul", "a": "mod_osc", "b": "mod_index"},
    {"id": "deviation", "op": "mul", "a": "dev_scale", "b": "mod_freq"},

    {"id": "car_freq", "op": "add", "a": "freq", "b": "deviation"},
    {"id": "car_phasor", "op": "phasor", "freq": "car_freq"},
    {"id": "car_osc", "op": "cycle", "buffer": "sine_tbl", "phase": "car_phasor"},

    {"id": "env", "op": "adsr", "gate": "gate",
     "attack": 10.0, "decay": 100.0, "sustain": 0.7, "release": 200.0},

    {"id": "env_scaled", "op": "mul", "a": "car_osc", "b": "env"},
    {"id": "output", "op": "mul", "a": "env_scaled", "b": "amp"}
  ]
}
